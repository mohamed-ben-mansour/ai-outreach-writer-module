# ================================
# APPLICATION
# ================================
APP_NAME=Agentic Outreach API
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# ================================
# SERVER
# ================================
HOST=0.0.0.0
PORT=8000

# ================================
# GOOGLE GEMINI
# ================================

GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_FALLBACK_MODEL=models/gemma-3-27b-it
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=4096

# ================================
# RESEARCH TOOLS
# ================================
USE_MOCK_DATA=true
LINKEDIN_API_KEY=
NEWS_API_KEY=
CRM_DATABASE_URL=

# ================================
# VALIDATION
# ================================
MIN_QUALITY_SCORE=80
MAX_ITERATIONS=3

# ================================
# LOGGING
# ================================
LOG_LEVEL=INFO
LOG_FILE=app.log

# ================================
# FEATURE FLAGS
# ================================
ENABLE_HUMAN_REVIEW=false
ENABLE_AUTO_SEND=false
ENABLE_LEARNING_LOOP=false

# ================================
# HUMAN IN THE LOOP
# ================================
ENABLE_HUMAN_REVIEW=true

# ================================
# EMAIL SENDING (Gmail SMTP — free)
# ================================
# 1. Enable 2FA on your Google account
# 2. Go to myaccount.google.com → Security → App Passwords
# 3. Generate a password for "Mail"
GMAIL_ADDRESS=mohamedbenmansour70@gmail.com
GMAIL_APP_PASSWORD=lmha xasj ijhk sfyj
# ================================
# LINKEDIN SENDING (Unipile)
# ================================
# Sign up at unipile.com, connect your LinkedIn account, get your DSN + API key
UNIPILE_API_KEY=your_unipile_api_key
UNIPILE_DSN=api4.unipile.com:13465
UNIPILE_DEFAULT_ACCOUNT_ID=your_linkedin_account_id_from_unipile
