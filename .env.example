# ================================
# APPLICATION
# ================================
APP_NAME=Agentic Outreach API
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# ================================
# SERVER
# ================================
HOST=0.0.0.0
PORT=8000

# ================================
# GOOGLE GEMINI
# ================================
# Get your key at https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash-exp
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=2048

# ================================
# RESEARCH TOOLS
# ================================
# Set to false when you have real API keys
USE_MOCK_DATA=true
LINKEDIN_API_KEY=your_linkedin_api_key_here
NEWS_API_KEY=your_news_api_key_here
CRM_DATABASE_URL=postgresql://user:password@localhost:5432/crm

# ================================
# VALIDATION
# ================================
MIN_QUALITY_SCORE=80
MAX_ITERATIONS=3

# ================================
# LOGGING
# ================================
LOG_LEVEL=INFO
LOG_FILE=app.log

# ================================
# FEATURE FLAGS
# ================================
ENABLE_HUMAN_REVIEW=false
ENABLE_AUTO_SEND=false
ENABLE_LEARNING_LOOP=false